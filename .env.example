# Copy to .env and fill in values for local development.

ANTHROPIC_API_KEY=sk-ant-...

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@noyolalearn.com
DIGEST_TO_EMAIL=mnoyola1@gmail.com
# Optional: comma-separated CC list (e.g. family members you want to loop in).
# In GitHub Actions this is sourced from the DIGEST_CC_EMAIL repo variable.
DIGEST_CC_EMAIL=

# Optional: raise GitHub API rate limit for trending fetch (any PAT, read-only scope ok).
# In GitHub Actions the built-in GITHUB_TOKEN is used automatically.
GITHUB_TOKEN=

# Optional: public base URL for archive links in the footer.
# When running via GitHub Actions, the workflow sets this from the repo slug.
DIGEST_ARCHIVE_BASE_URL=https://mnoyola1.github.io/n-digest/archive
